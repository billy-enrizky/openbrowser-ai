# API Configuration
# For production, use:
# NEXT_PUBLIC_API_URL=https://api.openbrowser.me
# NEXT_PUBLIC_WS_URL=wss://api.openbrowser.me/ws

# For local development:
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Cognito Authentication
# Set NEXT_PUBLIC_AUTH_ENABLED=true to require login.
NEXT_PUBLIC_AUTH_ENABLED=false
# NEXT_PUBLIC_COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com
# NEXT_PUBLIC_COGNITO_CLIENT_ID=your_app_client_id
# NEXT_PUBLIC_COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback
# NEXT_PUBLIC_COGNITO_LOGOUT_URI=http://localhost:3000/login
# NEXT_PUBLIC_COGNITO_SCOPES=openid email profile

# UI Configuration
# Application name and version (used in header)
NEXT_PUBLIC_APP_NAME=OpenBrowser
NEXT_PUBLIC_APP_VERSION=1.0

# Quick actions shown in chat input (JSON array)
# icon: Lucide icon name, label: Button text, color: Tailwind gradient classes, enabled: Show/hide
# Optional prompt: The message to send when clicked
# Set to empty array [] to hide all quick actions
NEXT_PUBLIC_QUICK_ACTIONS=[]

# Integrations shown in tools connection panel (JSON array)
# name: Integration name, enabled: Show/hide, url: Optional link to setup
# Set to empty array [] to hide all integrations
NEXT_PUBLIC_INTEGRATIONS=[]

# Integration panel text
NEXT_PUBLIC_INTEGRATION_TEXT=Connect your tools to OpenBrowser

# Default plan name shown when user info not loaded
NEXT_PUBLIC_DEFAULT_PLAN=Free plan

# Trial upgrade button text
NEXT_PUBLIC_TRIAL_CTA=Start free trial
